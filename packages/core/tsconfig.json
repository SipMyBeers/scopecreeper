{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true,
    "outDir": "dist",
    "rootDir": ".",
    "isolatedModules": true,
    "resolveJsonModule": true,
    "verbatimModuleSyntax": false
  },
  "include": [
    "scoring.ts",
    "github.ts",
    "chatlog.ts",
    "prompts.ts",
    "types.ts",
    "index.ts",
    "ingestion.ts"
  ]
}
